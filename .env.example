# Required: Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional: any multimodal Gemini model name. Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Optional: transport for the MCP server.
# "stdio" for local MCP clients (e.g. Claude Desktop/Code) launching the process directly.
# "streamable-http" for a server deployment reachable over HTTP (used by the Docker image).
MCP_TRANSPORT=stdio

# Optional: port used when MCP_TRANSPORT=streamable-http
PORT=8000
